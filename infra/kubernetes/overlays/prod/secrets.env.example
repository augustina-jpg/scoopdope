# Production Secrets Template
# Copy this file to secrets.env and fill in actual values
# IMPORTANT: Never commit secrets.env to version control!

# Database
DATABASE_HOST=postgres.production.svc.cluster.local
DATABASE_PORT=5432
DATABASE_USER=scoopdope_prod
DATABASE_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Redis
REDIS_URL=redis://redis.production.svc.cluster.local:6379

# Authentication
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_KEY

# Stellar
STELLAR_NETWORK=mainnet
STELLAR_SECRET_KEY=REPLACE_WITH_ACTUAL_KEY
STELLAR_HORIZON_URL=https://horizon.stellar.org

# Soroban
SOROBAN_RPC_URL=https://soroban-mainnet.stellar.org

# Google OAuth
GOOGLE_CLIENT_ID=REPLACE_WITH_ACTUAL_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_ACTUAL_SECRET

# Frontend
FRONTEND_URL=https://example.com
CORS_ORIGINS=https://example.com,https://www.example.com

# Email
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=REPLACE_WITH_SENDGRID_API_KEY

# Elasticsearch
ELASTICSEARCH_API_KEY=REPLACE_WITH_ACTUAL_KEY

# AWS
AWS_ACCESS_KEY_ID=REPLACE_WITH_ACTUAL_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_ACTUAL_SECRET

# Stripe
STRIPE_SECRET_KEY=REPLACE_WITH_ACTUAL_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_ACTUAL_SECRET

# Sentry
SENTRY_DSN=REPLACE_WITH_ACTUAL_DSN

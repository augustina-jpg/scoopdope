{
  "dashboard": {
    "title": "Scoopdope - Platform Observability",
    "uid": "Scoopdope-observability",
    "tags": ["scoopdope", "nestjs", "platform"],
    "timezone": "browser",
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "HTTP Request Rate (req/s)",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total[5m])) by (method, route, status_code)",
            "legendFormat": "{{method}} {{route}} {{status_code}}"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "reqps" }
        }
      },
      {
        "id": 2,
        "title": "HTTP Error Rate (5xx)",
        "type": "timeseries",
        "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m]))",
            "legendFormat": "5xx errors/s"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "reqps", "color": { "fixedColor": "red", "mode": "fixed" } }
        }
      },
      {
        "id": 3,
        "title": "HTTP Request Duration (p50 / p95 / p99)",
        "type": "timeseries",
        "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "p99"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "id": 4,
        "title": "Business Metrics",
        "type": "stat",
        "gridPos": { "x": 0, "y": 8, "w": 3, "h": 4 },
        "targets": [
          {
            "expr": "sum(enrollments_total)",
            "legendFormat": "Total Enrollments"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "fixed", "fixedColor": "blue" }
          }
        },
        "description": "Total course enrollments"
      },
      {
        "id": 5,
        "title": "Courses Completed",
        "type": "stat",
        "gridPos": { "x": 3, "y": 8, "w": 3, "h": 4 },
        "targets": [
          {
            "expr": "sum(courses_completed_total)",
            "legendFormat": "Total Completed"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "fixed", "fixedColor": "green" }
          }
        }
      },
      {
        "id": 6,
        "title": "Credentials Issued",
        "type": "stat",
        "gridPos": { "x": 6, "y": 8, "w": 3, "h": 4 },
        "targets": [
          {
            "expr": "sum(credential_issued_total)",
            "legendFormat": "Total"
          }
        ]
      },
      {
        "id": 7,
        "title": "BST Tokens Minted",
        "type": "stat",
        "gridPos": { "x": 9, "y": 8, "w": 3, "h": 4 },
        "targets": [
          {
            "expr": "sum(bst_minted_total)",
            "legendFormat": "Total"
          }
        ]
      },
      {
        "id": 8,
        "title": "Recommendations Served",
        "type": "stat",
        "gridPos": { "x": 12, "y": 8, "w": 3, "h": 4 },
        "targets": [
          {
            "expr": "sum(recommendations_served_total)",
            "legendFormat": "Total"
          }
        ]
      },
      {
        "id": 9,
        "title": "Health Check Status",
        "type": "stat",
        "gridPos": { "x": 15, "y": 8, "w": 3, "h": 4 },
        "targets": [
          {
            "expr": "sum(health_check_up{probe=\"readiness\"})",
            "legendFormat": "Ready"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": { "mode": "absolute", "steps": [{ "value": 0, "color": "red" }, { "value": 1, "color": "green" }] }
          }
        }
      },
      {
        "id": 10,
        "title": "Active Users (24h)",
        "type": "stat",
        "gridPos": { "x": 18, "y": 8, "w": 3, "h": 4 },
        "targets": [
          {
            "expr": "app_active_users{window=\"24h\"}",
            "legendFormat": "Active Users"
          }
        ]
      },
      {
        "id": 11,
        "title": "Enrollment Rate",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 12, "w": 8, "h": 8 },
        "targets": [
          {
            "expr": "sum(rate(enrollments_total[1h])) by (level)",
            "legendFormat": "{{level}}"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "ops" }
        }
      },
      {
        "id": 12,
        "title": "Completion Rate",
        "type": "timeseries",
        "gridPos": { "x": 8, "y": 12, "w": 8, "h": 8 },
        "targets": [
          {
            "expr": "sum(rate(courses_completed_total[1h])) by (level)",
            "legendFormat": "{{level}}"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "ops" }
        }
      },
      {
        "id": 13,
        "title": "Credential Issuance Rate",
        "type": "timeseries",
        "gridPos": { "x": 16, "y": 12, "w": 8, "h": 8 },
        "targets": [
          {
            "expr": "sum(rate(credential_issued_total[5m])) by (credential_type)",
            "legendFormat": "{{credential_type}}"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "ops" }
        }
      },
      {
        "id": 14,
        "title": "Cache Hit Rate",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 20, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "sum(rate(cache_hits_total[5m])) by (cache) / (sum(rate(cache_hits_total[5m])) by (cache) + sum(rate(cache_misses_total[5m])) by (cache)) * 100",
            "legendFormat": "{{cache}}"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "percent" }
        }
      },
      {
        "id": 15,
        "title": "Stellar RPC Latency p50 / p95 / p99",
        "type": "timeseries",
        "gridPos": { "x": 8, "y": 20, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(stellar_rpc_latency_seconds_bucket[5m])) by (le, method))",
            "legendFormat": "p50 {{method}}"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(stellar_rpc_latency_seconds_bucket[5m])) by (le, method))",
            "legendFormat": "p95 {{method}}"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(stellar_rpc_latency_seconds_bucket[5m])) by (le, method))",
            "legendFormat": "p99 {{method}}"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "id": 16,
        "title": "Node.js Memory Usage",
        "type": "timeseries",
        "gridPos": { "x": 16, "y": 20, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "process_resident_memory_bytes",
            "legendFormat": "RSS"
          },
          {
            "expr": "nodejs_heap_size_used_bytes",
            "legendFormat": "Heap Used"
          },
          {
            "expr": "nodejs_heap_size_total_bytes",
            "legendFormat": "Heap Total"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "bytes" }
        }
      },
      {
        "id": 17,
        "title": "Event Loop Lag",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 26, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "nodejs_eventloop_lag_seconds",
            "legendFormat": "Event Loop Lag"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "id": 18,
        "title": "CPU Usage",
        "type": "timeseries",
        "gridPos": { "x": 8, "y": 26, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "rate(process_cpu_user_seconds_total[1m])",
            "legendFormat": "User CPU"
          },
          {
            "expr": "rate(process_cpu_system_seconds_total[1m])",
            "legendFormat": "System CPU"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "percentunit" }
        }
      },
      {
        "id": 19,
        "title": "Active Connections & DB Pool",
        "type": "timeseries",
        "gridPos": { "x": 16, "y": 26, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "app_active_connections",
            "legendFormat": "Active Connections"
          },
          {
            "expr": "app_database_pool_size",
            "legendFormat": "DB Pool"
          },
          {
            "expr": "app_redis_connected_clients",
            "legendFormat": "Redis Clients"
          }
        ]
      }
    ],
    "schemaVersion": 38,
    "version": 3
  },
  "overwrite": true
}

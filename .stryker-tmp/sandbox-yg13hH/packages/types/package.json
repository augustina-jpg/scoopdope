{
  "name": "@scoopdope/types",
  "version": "1.0.0",
  "description": "Shared TypeScript types, DTOs and interfaces for scoopdope frontend and backend",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "src"
  ],
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
